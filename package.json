{
  "name": "@thierryvm/coda-mcp-server",
  "version": "2.2.0",
  "description": "MCP server for Coda.io API — list/read/write docs, pages, tables, rows and formulas",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coda-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run format:check && npm run build && npm test",
    "prepublishOnly": "npm run check"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "coda",
    "coda.io",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "thierryvm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thierryvm/coda-mcp-server.git"
  },
  "homepage": "https://github.com/thierryvm/coda-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
