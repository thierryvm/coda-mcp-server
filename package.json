{
  "name": "@thierryvm/coda-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Coda.io API — list/read/write docs, pages, tables, rows and formulas",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coda-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "coda",
    "coda.io",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "thierryvm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thierryvm/coda-mcp-server.git"
  },
  "homepage": "https://github.com/thierryvm/coda-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
